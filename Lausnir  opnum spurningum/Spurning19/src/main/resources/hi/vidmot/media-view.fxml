<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.media.MediaView?>

<VBox alignment="CENTER" prefHeight="179.0" prefWidth="194.0" spacing="10" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hi.vidmot.MediaController" stylesheets="@media-stylesheet.css">
    <HBox spacing="20">
        <Button fx:id="fxSpilaButton" onAction="#spila" text="Spila" styleClass="media-button" />
        <Button fx:id="fxPausaButton" onAction="#pausa" text="Pása" styleClass="media-button" />
        <Button fx:id="fxStoppaButton" onAction="#stoppa" text="Stöðva" styleClass="media-button" />
    </HBox>
    <MediaView fx:id="fxMediaView" />
    <ProgressBar fx:id="fxProgressBar" prefWidth="300" progress="0.0" styleClass="media-progressbar" />
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
</VBox>

